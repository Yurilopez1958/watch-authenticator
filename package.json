{
  "name": "watch-authenticator",
  "version": "0.1.0",
  "private": true,
  "description": "App multiplataforma para autenticar relojes por composición XRF y análisis visual",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
