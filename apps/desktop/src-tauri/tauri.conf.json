{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watch Authenticator",
  "version": "0.1.0",
  "identifier": "com.watchauth.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @watch-auth/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @watch-auth/web build && pnpm --filter @watch-auth/web exec next export -o ../desktop/dist",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Watch Authenticator",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Autenticación de relojes por XRF y análisis visual",
    "longDescription": "Cliente de escritorio para Watch Authenticator. Vigila la carpeta de exports del software Niton y sube las mediciones automáticamente a Supabase."
  },
  "plugins": {
    "fs": {
      "scope": ["$HOME/**", "$DOCUMENT/**", "$DOWNLOAD/**"]
    }
  }
}
