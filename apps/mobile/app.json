{
  "expo": {
    "name": "Watch Authenticator",
    "slug": "watch-authenticator",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watchauth.app"
    },
    "android": {
      "package": "com.watchauth.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Esta app necesita la cámara para fotografiar partes clave del reloj."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "$SUPABASE_URL",
      "supabaseAnonKey": "$SUPABASE_ANON_KEY"
    }
  }
}
